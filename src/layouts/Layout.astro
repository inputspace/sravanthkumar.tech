---
interface Props {
  title?: string;
  page?: string;
}
const { title = 'Sravanth Kumar', page = '' } = Astro.props;
const nav = [
  { href: '/', label: 'Home', icon: '🏠' },
  { href: '/projects', label: 'Projects', icon: '🛠️' },
  { href: '/blog', label: 'Blog', icon: '✍️' },
  { href: '/about', label: 'About', icon: '👤' },
];
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { height: 100%; }
      body {
        font-family: 'Inter', -apple-system, sans-serif;
        font-size: 15px;
        color: #37352f;
        background: #fff;
        display: flex;
        -webkit-font-smoothing: antialiased;
      }

      .sidebar {
        width: 240px;
        min-width: 240px;
        height: 100vh;
        position: sticky;
        top: 0;
        background: #f7f7f5;
        border-right: 1px solid #e9e9e7;
        display: flex;
        flex-direction: column;
        padding: 0.5rem 0;
        overflow-y: auto;
      }

      .sidebar-profile {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.6rem 0.75rem;
        margin: 0.25rem 0.5rem;
        border-radius: 6px;
      }

      .sidebar-avatar {
        width: 28px; height: 28px;
        border-radius: 6px;
        background: #37352f;
        color: white;
        font-size: 11px;
        font-weight: 600;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        letter-spacing: 0.02em;
      }

      .sidebar-name {
        font-size: 0.85rem;
        font-weight: 600;
        color: #37352f;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .sidebar-divider { height: 1px; background: #e9e9e7; margin: 0.35rem 0.75rem; }

      .sidebar-label {
        font-size: 0.68rem;
        font-weight: 600;
        color: #9b9a97;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        padding: 0.5rem 0.75rem 0.2rem;
      }

      .sidebar-link {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.3rem 0.75rem;
        margin: 0.1rem 0.5rem;
        border-radius: 4px;
        text-decoration: none;
        color: #37352f;
        font-size: 0.875rem;
        transition: background 0.1s;
      }
      .sidebar-link:hover { background: #efeeec; }
      .sidebar-link.active { background: #e8e8e5; font-weight: 500; }
      .sidebar-icon { font-size: 0.85rem; width: 20px; text-align: center; flex-shrink: 0; }

      .sidebar-footer {
        margin-top: auto;
        padding: 0.75rem 1rem;
        border-top: 1px solid #e9e9e7;
      }
      .sidebar-footer a {
        font-size: 0.78rem;
        color: #9b9a97;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.35rem;
      }
      .sidebar-footer a:hover { color: #37352f; }

      .main {
        flex: 1;
        min-width: 0;
        padding: 3rem 4rem 5rem;
        max-width: 780px;
      }

      .topbar {
        display: none;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 1rem;
        border-bottom: 1px solid #e9e9e7;
        background: #f7f7f5;
        position: sticky;
        top: 0;
        z-index: 10;
      }

      @media (max-width: 700px) {
        .sidebar { display: none; }
        .topbar { display: flex; }
        .main { padding: 1.5rem 1.25rem 4rem; }
        body { flex-direction: column; }
      }
    </style>
  </head>
  <body>
    <aside class="sidebar">
      <div class="sidebar-profile">
        <div class="sidebar-avatar">SK</div>
        <span class="sidebar-name">Sravanth Kumar</span>
      </div>
      <div class="sidebar-divider"></div>
      <div class="sidebar-label">Pages</div>
      {nav.map(n => (
        <a href={n.href} class={`sidebar-link${page === n.label ? ' active' : ''}`}>
          <span class="sidebar-icon">{n.icon}</span>
          {n.label}
        </a>
      ))}
      <div class="sidebar-footer">
        <a href="https://github.com/inputspace" target="_blank" rel="noopener">
          ↗ github.com/inputspace
        </a>
      </div>
    </aside>

    <div class="topbar">
      <div style="width:24px;height:24px;border-radius:4px;background:#37352f;color:white;font-size:10px;font-weight:600;display:flex;align-items:center;justify-content:center;flex-shrink:0;">SK</div>
      <span style="font-size:0.9rem;font-weight:600;">Sravanth Kumar</span>
    </div>

    <main class="main">
      <slot />
    </main>
  </body>
</html>
