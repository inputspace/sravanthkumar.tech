---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact — Sravanth Kumar" page="Contact">
  <style>
    .page-emoji { font-size: 3rem; margin-bottom: 0.5rem; display: block; }
    h1 { font-size: 2rem; font-weight: 700; letter-spacing: -0.03em; color: #37352f; margin-bottom: 0.35rem; }
    .subtitle { font-size: 0.9rem; color: #9b9a97; margin-bottom: 2rem; }
    .divider { border: none; border-top: 1px solid #e9e9e7; margin: 1.5rem 0; }
    h2 { font-size: 0.875rem; font-weight: 600; color: #9b9a97; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.75rem; }

    .contact-list { display: flex; flex-direction: column; gap: 0; }
    .contact-row {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 0.7rem 0;
      border-bottom: 1px solid #f0f0ee;
      font-size: 0.875rem;
    }
    .contact-row:first-child { border-top: 1px solid #f0f0ee; }
    .contact-icon { width: 28px; height: 28px; background: #f1f1ef; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 0.9rem; flex-shrink: 0; }
    .contact-label { color: #9b9a97; width: 80px; min-width: 80px; font-size: 0.825rem; }
    .contact-val a { color: #2563eb; text-decoration: none; }
    .contact-val a:hover { text-decoration: underline; }
    .contact-val { color: #37352f; }

    .callout { background: #f7f7f5; border: 1px solid #e9e9e7; border-radius: 6px; padding: 0.75rem 1rem; font-size: 0.875rem; color: #37352f; display: flex; gap: 0.6rem; margin-top: 1.5rem; line-height: 1.6; }
  </style>

  <span class="page-emoji">✉️</span>
  <h1>Contact</h1>
  <p class="subtitle">Open to collaborations, opportunities, or just a good conversation.</p>

  <hr class="divider" />

  <h2>Reach me at</h2>
  <div class="contact-list">
    <div class="contact-row">
      <div class="contact-icon">📧</div>
      <span class="contact-label">Email</span>
      <span class="contact-val"><a href="mailto:sravanthkumarx@gmail.com">sravanthkumarx@gmail.com</a></span>
    </div>
    <div class="contact-row">
      <div class="contact-icon">🐙</div>
      <span class="contact-label">GitHub</span>
      <span class="contact-val"><a href="https://github.com/inputspace" target="_blank" rel="noopener">github.com/inputspace</a></span>
    </div>
    <div class="contact-row">
      <div class="contact-icon">🌐</div>
      <span class="contact-label">Website</span>
      <span class="contact-val">sravanthkumar.tech</span>
    </div>
  </div>

  <div class="callout">
    <span>💬</span>
    <span>Best way to reach me is email. I usually respond within a day or two.</span>
  </div>
</Layout>
