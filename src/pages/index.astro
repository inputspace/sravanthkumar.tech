---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const featured = projects.sort((a, b) => (b.data.featured ? 1 : 0) - (a.data.featured ? 1 : 0));
---

<Layout title="Sravanth Kumar — Builder & Support Engineer">
  <div class="container">

    <nav>
      <a class="nav-name" href="/">Sravanth Kumar</a>
      <ul class="nav-links">
        <li><a href="#projects">Projects</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
    </nav>

    <!-- Hero -->
    <section class="hero">
      <div class="hero-label">Available for opportunities</div>
      <h1 class="hero-name">
        Sravanth<br /><em>Kumar</em>
      </h1>
      <p class="hero-bio">
        Application Support Engineer at an EdTech company. I build tools for people who think differently — productivity apps, personal systems, and things that make quiet work visible.
      </p>
      <div class="hero-status">
        <span class="status-dot"></span>
        Based in Khammam, India
      </div>
    </section>

    <!-- Projects -->
    <section class="section" id="projects">
      <div class="section-header">
        <span class="section-num">01</span>
        <h2 class="section-title">Things I've built</h2>
      </div>

      <div class="projects-grid">
        {featured.map((project) => (
          <div class="project-card">
            <div>
              <h3 class="project-title">{project.data.title}</h3>
              <p class="project-desc">{project.data.description}</p>
              {project.data.tags && (
                <div class="project-tags">
                  {project.data.tags.map(tag => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              )}
            </div>
            {project.data.link && (
              <a class="project-link" href={project.data.link} target="_blank" rel="noopener">
                View ↗
              </a>
            )}
          </div>
        ))}
      </div>
    </section>

    <!-- About -->
    <section class="section" id="about">
      <div class="section-header">
        <span class="section-num">02</span>
        <h2 class="section-title">About me</h2>
      </div>

      <div class="about-grid">
        <div class="about-text">
          <p>
            I'm a support engineer with a builder's mindset. My day job is keeping EdTech systems running — my real interest is building tools that help sensitive, neurodivergent people work better.
          </p>
          <p>
            I've been using Notion as a self-awareness and planning system since 2019. Most of what I build starts as a personal problem I needed to solve.
          </p>
        </div>

        <ul class="skills-list">
          <li>Application Support</li>
          <li>React / Vite</li>
          <li>Vibe Coding</li>
          <li>Anthropic API</li>
          <li>Notion Power User</li>
          <li>System Building</li>
        </ul>
      </div>
    </section>

    <!-- Contact -->
    <section class="section" id="contact">
      <div class="section-header">
        <span class="section-num">03</span>
        <h2 class="section-title">Get in touch</h2>
      </div>

      <div class="contact-links">
        <a class="contact-link" href="mailto:sravanthkumarx@gmail.com">
          ↳ sravanthkumarx@gmail.com
        </a>
        <a class="contact-link" href="https://github.com/inputspace" target="_blank" rel="noopener">
          ↳ github.com/inputspace
        </a>
      </div>
    </section>

    <footer>
      <span class="footer-text">© 2025 Sravanth Kumar</span>
      <span class="footer-text">sravanthkumar.tech</span>
    </footer>

  </div>
</Layout>
