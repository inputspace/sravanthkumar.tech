---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const sorted = projects.sort((a, b) => (b.data.featured ? 1 : 0) - (a.data.featured ? 1 : 0));
---

<Layout title="Sravanth Kumar — Builder & Support Engineer">
  <div class="container">

    <nav>
      <a class="nav-name" href="/">Sravanth Kumar</a>
      <ul class="nav-links">
        <li><a href="#projects">Projects</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
    </nav>

    <section class="hero">
      <div class="hero-eyebrow">
        <span class="hero-eyebrow-dot"></span>
        Open to opportunities
      </div>
      <h1 class="hero-name">Sravanth Kumar</h1>
      <p class="hero-tagline">
        Application Support Engineer & builder of tools for people who think differently.
        Based in Khammam, India.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="#projects">See my work</a>
        <a class="btn btn-ghost" href="#contact">Get in touch</a>
      </div>
    </section>

    <section class="section" id="projects">
      <p class="section-label">Work</p>
      <h2 class="section-title">Things I've built</h2>
      <p class="section-desc">Personal tools, productivity apps, and experiments — mostly things I needed myself.</p>

      <div class="projects-list">
        {sorted.map((project) => (
          <a
            class="project-item"
            href={project.data.link || '#'}
            target={project.data.link ? '_blank' : '_self'}
            rel="noopener"
          >
            <div>
              <p class="project-title">{project.data.title}</p>
              <p class="project-desc">{project.data.description}</p>
              {project.data.tags && (
                <div class="project-tags">
                  {project.data.tags.map(tag => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              )}
            </div>
            <span class="project-arrow">↗</span>
          </a>
        ))}
      </div>
    </section>

    <section class="section" id="about">
      <p class="section-label">About</p>
      <h2 class="section-title">A bit about me</h2>

      <div class="about-text">
        <p>
          I'm a support engineer with a builder's mindset. My day job is keeping EdTech systems
          running smoothly — but what I really enjoy is building tools that help people work better.
        </p>
        <p>
          I've been using Notion as a self-awareness and planning system since 2019. Most of what
          I build starts as a personal problem I needed to solve.
        </p>
      </div>

      <div class="skills-grid">
        <span class="skill-chip">React / Vite</span>
        <span class="skill-chip">Electron</span>
        <span class="skill-chip">Anthropic API</span>
        <span class="skill-chip">App Support</span>
        <span class="skill-chip">Notion</span>
        <span class="skill-chip">System Building</span>
      </div>
    </section>

    <section class="section" id="contact">
      <p class="section-label">Contact</p>
      <h2 class="section-title">Get in touch</h2>
      <p class="section-desc">Open to collaborations, opportunities, or just a good conversation.</p>

      <div class="contact-links">
        <a class="contact-link" href="mailto:sravanthkumarx@gmail.com">
          ✉ sravanthkumarx@gmail.com
        </a>
        <a class="contact-link" href="https://github.com/inputspace" target="_blank" rel="noopener">
          ↗ github.com/inputspace
        </a>
      </div>
    </section>

    <footer>
      <span class="footer-text">© 2025 Sravanth Kumar</span>
      <span class="footer-text">sravanthkumar.tech</span>
    </footer>

  </div>
</Layout>
