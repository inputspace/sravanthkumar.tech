---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
const projects = await getCollection('projects');
const sorted = projects.sort((a,b) => (b.data.featured ? 1 : 0) - (a.data.featured ? 1 : 0));
---
<Layout title="Projects — Sravanth Kumar" page="Projects">
  <style>
    .page-emoji { font-size: 2.5rem; margin-bottom: 0.4rem; display: block; }
    h1 { font-size: 1.75rem; font-weight: 700; letter-spacing: -0.03em; color: #37352f; margin-bottom: 0.35rem; }
    .subtitle { font-size: 0.875rem; color: #9b9a97; margin-bottom: 2rem; }
    .divider { border: none; border-top: 1px solid #e9e9e7; margin: 1.25rem 0; }
    .project-row { display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; padding: 0.9rem 0; border-bottom: 1px solid #f0f0ee; text-decoration: none; color: inherit; }
    .project-row:first-child { border-top: 1px solid #f0f0ee; }
    .project-row:hover .project-title { color: #2563eb; }
    .project-title { font-size: 0.925rem; font-weight: 500; color: #37352f; margin-bottom: 0.25rem; transition: color 0.1s; display: flex; align-items: center; gap: 0.4rem; }
    .project-desc { font-size: 0.825rem; color: #9b9a97; line-height: 1.5; margin-bottom: 0.5rem; }
    .tags { display: flex; flex-wrap: wrap; gap: 0.3rem; }
    .tag { font-size: 0.68rem; background: #f1f1ef; color: #6b6b6b; border-radius: 3px; padding: 0.12rem 0.45rem; }
    .badge { font-size: 0.62rem; font-weight: 500; background: #fef9c3; color: #854d0e; border-radius: 3px; padding: 0.1rem 0.4rem; }
    .arrow { color: #c7c6c3; font-size: 0.8rem; flex-shrink: 0; margin-top: 0.15rem; }
  </style>

  <span class="page-emoji">🛠️</span>
  <h1>Projects</h1>
  <p class="subtitle">Things I've built — mostly starting from a personal need.</p>
  <hr class="divider" />

  {sorted.map(p => (
    <a class="project-row" href={p.data.link || '#'} target={p.data.link ? '_blank' : '_self'} rel="noopener">
      <div style="flex:1;min-width:0;">
        <div class="project-title">
          {p.data.title}
          {p.data.featured && <span class="badge">Featured</span>}
        </div>
        <p class="project-desc">{p.data.description}</p>
        {p.data.tags && <div class="tags">{p.data.tags.map((t: string) => <span class="tag">{t}</span>)}</div>}
      </div>
      {p.data.link && <span class="arrow">↗</span>}
    </a>
  ))}
</Layout>
